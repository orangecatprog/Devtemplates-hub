{
	"name": "devtemplates-hub",
	"module": "src/index.ts",
	"type": "module",
	"scripts": {
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"check": "eslint . && prettier --check .",
		"prepare": "husky",
		"lint-staged": "lint-staged",
		"test": "vitest",
		"test:all": "vitest --dir=src",
		"test:shared": "vitest --dir=src/shared",
		"test:template": "vitest --dir=src/template",
		"test:user": "vitest --dir=src/user",
		"test:category": "vitest --dir=src/category",
		"test:technology": "vitest --dir=src/technology",
		"test:comment": "vitest --dir=src/comment",
		"test:review": "vitest --dir=src/review",
		"test:favorite": "vitest --dir=src/favorite",
		"test:download": "vitest --dir=src/download",
		"test:watch": "vitest --dir=src --watch",
		"coverage": "vitest run --coverage --dir=src --watch",
		"coverage:watch": "vitest --dir=src --watch --coverage"
	},
	"devDependencies": {
		"@commitlint/cli": "^21.2.0",
		"@commitlint/config-conventional": "^21.2.0",
		"@eslint/css": "^1.4.0",
		"@eslint/js": "^10.0.1",
		"@eslint/json": "^2.0.1",
		"@eslint/markdown": "^8.0.3",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.1.0",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"prettier": "3.9.5",
		"typescript-eslint": "^8.63.0",
		"vitest": "^4.1.9"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"zod": "^4.4.3"
	}
}
